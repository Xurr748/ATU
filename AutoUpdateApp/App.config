<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- Root directory for config files (network share or local) -->
    <add key="ConfigRoot" value="\\server\share\UpdateConfig\" />

    <!-- Relative to ConfigRoot (or absolute paths) -->
    <add key="TesterTypePath" value="TesterType.csv" />
    <add key="VersionFilePath" value="version.txt" />
    <add key="UpdateFlagPath" value="updateflag.txt" />

    <!-- Installer paths by tester type -->
    <add key="InstallerPathHE" value="\\server\share\Installers\HE\setup.exe" />
    <add key="InstallerPathLLE" value="\\server\share\Installers\LLE\setup.exe" />
    <add key="InstallerArgs" value="/silent /norestart" />

    <!-- Registry location for current installed version -->
    <add key="RegistryKeyPath" value="HKEY_LOCAL_MACHINE\SOFTWARE\MyApp" />
    <add key="RegistryValueName" value="Version" />

    <!-- Logging -->
    <add key="LogPath" value="C:\Logs\AutoUpdate\" />
    <add key="LogLevel" value="Info" />

    <!-- Scheduler polling interval in minutes -->
    <add key="PollingIntervalMinutes" value="60" />
  </appSettings>
</configuration>
