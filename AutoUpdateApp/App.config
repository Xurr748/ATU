<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>

    <add key="ConfigRoot" value="" />


    <add key="TesterTypePath" value="C:\Users\User\Desktop\Atupd\SampleConfig\TesterType.csv" />
    <add key="VersionFilePath" value="5555\mode\version.txt" />
    <add key="UpdateFlagPath" value="5555\mode\updateflag.txt" />


    <add key="InstallerPathHE" value="testupd\version\HE" />
    <add key="InstallerPathLLE" value="testupd\version\LLE" />
    <add key="InstallerArgs" value="/silent /norestart" />

    <add key="RegistryKeyPath" value="HKEY_LOCAL_MACHINE\SOFTWARE\dotnet\Setup\InstalledVersions\x64\sharedhost" />
    <add key="RegistryValueName" value="Version" />
    <add key="RegistryPathValueName" value="Path" />
    <add key="CompanyName" value="CompanyName" />


    <add key="LogPath" value="5555\mode" />
    <add key="LogFileName" value="{ComputerName}_Logs.txt" />
    <add key="LogLevel" value="Info" />

    <add key="PollingIntervalMinutes" value="60" />
  </appSettings>
</configuration>
