<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- โฟลเดอร์หลักสำหรับไฟล์ Config -->
    <add key="ConfigRoot" value="5555\mode" />

    <!-- เส้นทางไฟล์ Config ต่างๆ -->
    <add key="TesterTypePath" value="5555\mode\testertype.csv" />
    <add key="VersionFilePath" value="5555\mode\version.txt" />
    <add key="UpdateFlagPath" value="5555\mode\updateflag.txt" />

    <!-- เส้นทาง Installer แยกตามประเภทเครื่องทดสอบ (โฟลเดอร์ที่มี setup.exe) -->
    <add key="InstallerPathHE" value="testupd\version\HE" />
    <add key="InstallerPathLLE" value="testupd\version\LLE" />
    <add key="InstallerArgs" value="/silent /norestart" />

    <!--
      ตำแหน่ง Registry สำหรับอ่านเวอร์ชันที่ติดตั้งอยู่
      ═══ ใส่ path เอง ═══
      RegistryKeyPath = เส้นทาง Registry Key เต็ม
        ตัวอย่าง: HKEY_LOCAL_MACHINE\SOFTWARE\MyCompany\MyApp
        ตัวอย่าง: HKEY_CURRENT_USER\SOFTWARE\TestSuite
      RegistryValueName = ชื่อ Value ใน Key นั้นที่เก็บเลขเวอร์ชัน
        ตัวอย่าง: Version
        ตัวอย่าง: CurrentVersion
    -->
    <add key="RegistryKeyPath" value="ใส่ path ของ RegistryKeyPath" />
    <add key="RegistryValueName" value="ใส่ชื่อ Value ของ RegistryValueName" />

    <!-- การบันทึก Log -->
    <add key="LogPath" value="5555\mode" />
    <add key="LogLevel" value="Info" />

    <!-- ระยะเวลาตรวจสอบ (นาที) -->
    <add key="PollingIntervalMinutes" value="60" />
  </appSettings>
</configuration>
