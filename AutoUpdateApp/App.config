<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- โฟลเดอร์หลักสำหรับไฟล์ Config (Network Share หรือ Local) -->
    <add key="ConfigRoot" value="ใส่ path ของ ConfigRoot" />

    <!-- เส้นทางสัมพัทธ์กับ ConfigRoot (หรือใส่ path เต็มก็ได้) -->
    <add key="TesterTypePath" value="ใส่ path ของ TesterTypePath" />
    <add key="VersionFilePath" value="ใส่ path ของ VersionFilePath" />
    <add key="UpdateFlagPath" value="ใส่ path ของ UpdateFlagPath" />

    <!-- เส้นทาง Installer แยกตามประเภทเครื่องทดสอบ -->
    <add key="InstallerPathHE" value="ใส่ path ของ InstallerPathHE" />
    <add key="InstallerPathLLE" value="ใส่ path ของ InstallerPathLLE" />
    <add key="InstallerArgs" value="/silent /norestart" />

    <!-- ตำแหน่ง Registry สำหรับเก็บเวอร์ชันปัจจุบันที่ติดตั้ง -->
    <add key="RegistryKeyPath" value="ใส่ path ของ RegistryKeyPath" />
    <add key="RegistryValueName" value="ใส่ชื่อ Value ของ RegistryValueName" />

    <!-- การบันทึก Log -->
    <add key="LogPath" value="ใส่ path ของ LogPath" />
    <add key="LogLevel" value="Info" />

    <!-- ระยะเวลาตรวจสอบ (นาที) -->
    <add key="PollingIntervalMinutes" value="60" />
  </appSettings>
</configuration>
